# 거래소 API 키 (실거래 시에만 필요. 둘 다 있어야 실거래, 하나라도 없으면 dry_run)
# Upbit
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=
# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=

# 분할매매 설정 (config.py load_config_from_env 이 읽는다)
SPLIT_MARKET_TYPE=crypto          # "crypto" | "stock"
SPLIT_EXCHANGE=upbit
SPLIT_SYMBOL=BTC/KRW
SPLIT_TOTAL_INVESTMENT=1000000
SPLIT_COUNT=5
SPLIT_TRIGGER_TYPE=price_drop     # "price_drop" | "time_interval"
SPLIT_TRIGGER_VALUE=3             # price_drop: % 하락폭, time_interval: 분 단위 간격
SPLIT_TARGET_PROFIT_PCT=5         # 평단 대비 목표 수익률 %
SPLIT_DRY_RUN=true                # 1/true/yes/on -> True
